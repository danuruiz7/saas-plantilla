NODE_ENV=development
PORT=3000

# PostgreSQL (Docker)
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=your_db_name
POSTGRES_PORT=5432

# Used by drizzle-kit locally (points to localhost)
# In Docker, this is overridden by docker-compose with the service hostname
DATABASE_URL=postgresql://your_db_user:your_db_password@localhost:5432/your_db_name

# Access token expiry (short — recommend 15m with refresh tokens)
JWT_EXPIRES_IN=15m
# Refresh token expiry
JWT_REFRESH_EXPIRES_IN=30d

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
EMAIL_FROM=no-reply@yourdomain.com
APP_URL=http://localhost:3001
APP_NAME=SaaS Backend

# OTP expiry in minutes
OTP_EXPIRES_IN_MINUTES=10

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3001

# Stripe
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# AWS S3 Storage (e.g. AWS, Cloudflare R2, MinIO, etc)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_S3_BUCKET=your_bucket_name
# AWS_S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# AWS_S3_CDN_URL=https://your-custom-cdn-domain.com
